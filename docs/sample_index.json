    {"file": "full-mixes/Parte1_Dub_Reggae.mp3", "genre": ["dub","reggae"], "type": ["full-mix"], "instrument": ["bass","drums","vocal","guitar","turntable"], "mood": ["hypnotic","groovy"], "energy": "mid", "source": "archive-org", "license": "unknown", "duration": "60:00", "notes": "PARTE 1 DUB REGGAE - Spanish-language dub/reggae radio show featuring Lee Perry 'People Funny Boy' (1968 Upsetter Records), The Upsetters, Bob Marley & The Wailers 'Sun Is Shining' (Lee Perry sessions), Burt Walters & The Upsetters. Deep roots reggae and dub — classic source material for dub techno, trip-hop, and downtempo producers. Heavy on reverb, delay, and bass weight."},
    {"file": "full-mixes/Robodub_Dub_Tech_Mix.mp3", "genre": ["dub","house","tech-house"], "type": ["full-mix"], "instrument": ["synth","drums","bass","turntable"], "mood": ["hypnotic","groovy","dark"], "energy": "mid", "source": "archive-org", "license": "unknown", "duration": "60:00", "notes": "Robodub - Dub Tech Mix. Fusion of Jamaican dub production techniques with minimal techno and tech house. Heavy sub-bass, spring reverb, tape delay, and sparse percussive textures. Bridges the gap between roots dub and Berlin-style minimal — useful for extracting dubby textures, bass hits, and atmospheric FX."},

    {"file": "full-mixes/Rahaan_Birthday_Mix.mp3", "genre": ["disco","funk","soul","rare-groove"], "type": ["full-mix"], "instrument": ["bass","drums","horn","vocal","turntable","piano"], "mood": ["euphoric","groovy","fun"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "60:00", "notes": "DJ Rahaan's Birthday Mix (March 28, 2007). Rahaan is a legendary Chicago DJ known for deep digging — rare disco, boogie, soul, and funk 12-inches. This mix is a masterclass in disco/funk curation. Expect rare grooves, extended breakdowns, and percussive sections perfect for sampling drum breaks, horn stabs, string swells, and bass riffs. Chicago house roots run deep here."},
    {"file": "full-mixes/MarkieMark_Disco_Funk_Soul.mp3", "genre": ["disco","funk","soul","rare-groove"], "type": ["full-mix"], "instrument": ["bass","drums","horn","vocal","turntable","piano","guitar"], "mood": ["euphoric","groovy","fun"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "120:00", "notes": "Markie Mark - Disco, Funk and Soul Mix (Aug 22, 2004). Extended 2-hour DJ mix spanning classic disco, funk, and soul records. Perfect source material for chopping breaks, lifting horn sections, isolating bass grooves. The extended format means lots of instrumental breakdowns to mine. Think Chic, Earth Wind & Fire, Parliament era production quality."},

    {"file": "full-mixes/DrHerom_Psycho.mp3", "genre": ["gabber","hardcore-techno","industrial"], "type": ["full-mix"], "instrument": ["synth","drums","drum-machine"], "mood": ["aggressive","chaotic","dark"], "energy": "extreme", "source": "archive-org", "license": "unknown", "duration": "6:30", "notes": "Dr. Herom - Psycho, from 'Mental Beats' (2009). Mexican gabber/hardcore techno — distorted kick drums 180+ BPM, aggressive synth stabs, industrial textures. Gabber emerged in early 90s Rotterdam (Thunderdome, Rotterdam Terror Corps). This is the Latin American branch of that lineage. Extreme tempo and distortion make it useful for industrial, noise, and speedcore production."},
    {"file": "full-mixes/DrHerom_Darkness.mp3", "genre": ["gabber","hardcore-techno","industrial"], "type": ["full-mix"], "instrument": ["synth","drums","drum-machine"], "mood": ["dark","aggressive","intense"], "energy": "extreme", "source": "archive-org", "license": "unknown", "duration": "7:00", "notes": "Dr. Herom - Darkness, from 'Mental Beats' (2009). Dark gabber with heavy industrial influence — pounding distorted kicks, ominous pads, horror-movie atmospherics. Useful for extracting punishing kick drum hits, dark ambient textures, and noise sweeps."},
    {"file": "full-mixes/DrHerom_HarderThanBefore.mp3", "genre": ["gabber","hardcore-techno"], "type": ["full-mix"], "instrument": ["synth","drums","drum-machine","vocal"], "mood": ["aggressive","intense","euphoric"], "energy": "extreme", "source": "archive-org", "license": "unknown", "duration": "5:30", "notes": "Dr. Herom - Harder Than Before, from 'Mental Beats' (2009). Peak-time gabber anthem with hoover synths, pitched-up vocal samples, and relentless 4/4 distorted kicks. The hoover synth (Roland Alpha Juno mentasm patch) is a defining sound of hardcore rave culture."},
    {"file": "full-mixes/DrHerom_ThisIsDeath.mp3", "genre": ["gabber","hardcore-techno","noise"], "type": ["full-mix"], "instrument": ["synth","drums","drum-machine","noise-generator"], "mood": ["aggressive","dark","chaotic"], "energy": "extreme", "source": "archive-org", "license": "unknown", "duration": "5:30", "notes": "Dr. Herom - This Is Death, from 'Mental Beats' (2009). Noise-infused gabber pushing into speedcore territory. Completely unhinged distortion, feedback loops, and tempo changes. Source material for power electronics, harsh noise wall, and industrial projects."},

    {"file": "drums-bank/SH_Levy_Break.mp3", "genre": ["breakbeat","funk","hip-hop"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["groovy","raw"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "2:00", "notes": "Simon Harris 'Broken Beaten & Scratched' (1989) - Levy Break. This album was one of the first commercially released breakbeat compilation records, designed explicitly for DJs and producers to sample from. Each track is a clean drum break loop. The Levy Break is a tight, funky break with snappy snare and crisp hi-hats — widely used in UK breakbeat hardcore and jungle."},
    {"file": "drums-bank/SH_Cold_Sweat.mp3", "genre": ["breakbeat","funk","hip-hop"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["groovy","intense"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "1:30", "notes": "Simon Harris - Cold Sweat break. Named after the James Brown classic — this is a funky, driving break with heavy kick emphasis. James Brown's 'Cold Sweat' (1967) with Clyde Stubblefield on drums was one of the first funk records and has been sampled thousands of times across hip-hop, jungle, and electronic music."},
    {"file": "drums-bank/SH_Memphis_Groove.mp3", "genre": ["breakbeat","funk","soul"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["groovy","fun"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "2:20", "notes": "Simon Harris - Memphis Groove break. Southern soul/funk influenced break with a looser, swinging feel. Memphis was home to Stax Records (Otis Redding, Isaac Hayes, Booker T. & the MGs) and Al Green's Hi Records. That lazy, behind-the-beat Memphis groove is in this break's DNA."},
    {"file": "drums-bank/SH_Apache.mp3", "genre": ["breakbeat","hip-hop","funk"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["groovy","raw","intense"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "2:10", "notes": "Simon Harris' take on the Apache break — the most sampled drum break in history. Originally by The Incredible Bongo Band (1973), it became the foundation of hip-hop when DJ Kool Herc isolated it at block parties in the Bronx. Used by Nas, Missy Elliott, Beastie Boys, Fatboy Slim, and hundreds more. This is the Simon Harris re-performed version for clean sampling."},
    {"file": "drums-bank/SH_Voodoo.mp3", "genre": ["breakbeat","funk"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["dark","groovy"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "1:50", "notes": "Simon Harris - Voodoo break. Dark, heavy funk break with a sinister quality. The name evokes New Orleans voodoo funk — think Dr. John, The Meters, and Allen Toussaint's productions. Deep pocket groove with emphasis on ghost notes and syncopation."},
    {"file": "drums-bank/SH_Bongola.mp3", "genre": ["breakbeat","funk","exotica"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["groovy","fun"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "2:10", "notes": "Simon Harris - Bongola break. Latin/Afro-influenced percussion break with bongo-heavy patterns. Bridges funk and Latin jazz — the kind of percussive groove sampled extensively in acid jazz, trip-hop, and early UK garage. Think DJ Shadow, Amon Tobin."},
    {"file": "drums-bank/SH_Skaville.mp3", "genre": ["breakbeat","ska","reggae"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["fun","groovy"], "energy": "mid", "source": "archive-org", "license": "unknown", "duration": "1:00", "notes": "Simon Harris - Skaville break. Ska-influenced break with the characteristic offbeat emphasis and shuffling rimshot pattern. Ska originated in Jamaica in the late 1950s as a precursor to rocksteady and reggae. This break captures that pre-reggae bounce."},
    {"file": "drums-bank/SH_Rumble_Riddim.mp3", "genre": ["breakbeat","reggae","dub"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["groovy","hypnotic"], "energy": "mid", "source": "archive-org", "license": "unknown", "duration": "2:15", "notes": "Simon Harris - Rumble Riddim break. Reggae/dub influenced rhythm with heavy one-drop pattern and deep bass drum. The riddim (Jamaican patois for 'rhythm') tradition of reusing drum patterns across dozens of different songs makes this especially relevant for production — one break, infinite versions."},
    {"file": "drums-bank/SH_Drum_Culture.mp3", "genre": ["breakbeat","funk"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["intense","raw"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "1:50", "notes": "Simon Harris - Drum Culture break. Aggressive, stripped-down funk break focused on raw snare hits and kick patterns. The name nods to the late 80s/early 90s culture where drum breaks became the currency of hip-hop and dance music production — DJs traded breaks like gold."},
    {"file": "drums-bank/SH_Rolling_Thunder.mp3", "genre": ["breakbeat","funk"], "type": ["drum-break"], "instrument": ["drums"], "mood": ["intense","aggressive"], "energy": "high", "source": "archive-org", "license": "unknown", "duration": "2:10", "notes": "Simon Harris - Rolling Thunder break. Heavy, rolling break with fast snare fills and powerful kick drum — the kind of break that drove early jungle and hardcore rave music. Named for the continuous, thundering quality of the drum rolls. Useful at both original tempo and time-stretched for half-time hip-hop."}
